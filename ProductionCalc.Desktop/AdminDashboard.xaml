<Window x:Class="ProductionCalc.Desktop.AdminDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin Dashboard"
        Width="1100" Height="760"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        FontFamily="Segoe UI"
        FontSize="13">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#1A73E8" CornerRadius="10" Padding="12 10" Margin="0 0 0 12">
            <DockPanel>
                <TextBlock Text="Admin Dashboard"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="White"
                           DockPanel.Dock="Left"/>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="txtUserDisplay"
                               Foreground="White"
                               FontWeight="SemiBold"
                               Margin="0 0 12 0"
                               VerticalAlignment="Center"/>
                    <Button Content="Logout"
                            Click="Logout_Click"
                            Padding="10 5"
                            Background="White"
                            Foreground="#1A73E8"
                            BorderBrush="#1A73E8"
                            BorderThickness="1"
                            FontWeight="SemiBold"
                            Cursor="Hand"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- MAIN CONTENT -->
        <Border Grid.Row="1" 
                Background="White" 
                CornerRadius="10"
                Padding="14"
                BorderBrush="#D0D7DE"
                BorderThickness="1"
                SnapsToDevicePixels="True">

            <TabControl Margin="4">
                <!-- USER MANAGEMENT TAB -->
                <TabItem Header="User Management">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DataGrid x:Name="UsersGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  CanUserAddRows="False"
                                  RowBackground="White"
                                  AlternatingRowBackground="#F9FBFC"
                                  GridLinesVisibility="None"
                                  BorderThickness="0"
                                  Margin="0,0,0,10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="200"/>
                                <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="120"/>
                                <DataGridTextColumn Header="Assigned Field" Binding="{Binding AssignedField}" Width="150"/>
                                <DataGridTextColumn Header="Last Login" Binding="{Binding LastLogin, StringFormat={}{0:g}}" Width="160"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                            <Button Content="Add User"
                                    Width="110"
                                    Background="#1A73E8"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Margin="0 0 8 0"
                                    Click="AddUser_Click"/>

                            <Button Content="Edit User"
                                    Width="110"
                                    Background="#34A853"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Margin="0 0 8 0"
                                    Click="EditUser_Click"/>

                            <Button Content="Delete User"
                                    Width="110"
                                    Background="#E74C3C"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Click="DeleteUser_Click"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- FIELD MANAGEMENT TAB -->
                <TabItem Header="Field Management">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DataGrid x:Name="FieldsGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  CanUserAddRows="False"
                                  RowBackground="White"
                                  AlternatingRowBackground="#F9FBFC"
                                  GridLinesVisibility="None"
                                  BorderThickness="0"
                                  Margin="0,0,0,10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Field Name" Binding="{Binding Name}" Width="*" />
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="220" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                            <Button Content="Add Field"
                                    Width="110"
                                    Background="#1A73E8"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Margin="0 0 8 0"
                                    Click="AddField_Click"/>

                            <Button Content="Edit Field"
                                    Width="110"
                                    Background="#34A853"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Margin="0 0 8 0"
                                    Click="EditField_Click"/>

                            <Button Content="Delete Field"
                                    Width="110"
                                    Background="#E74C3C"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Click="DeleteField_Click"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- SYSTEM REPORTS TAB -->
                <TabItem Header="System Reports">
                    <StackPanel Margin="12">
                        <TextBlock Text="System Reports &amp;Exports"
                                   FontWeight="SemiBold"
                                   FontSize="15"
                                   Foreground="#333"
                                   Margin="0 0 0 8"/>
                        <Button Content="Export All Reports (CSV)"
                                Width="220"
                                Background="#1A73E8"
                                Foreground="White"
                                BorderThickness="0"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                Click="ExportAllReports_Click"
                                Margin="0 0 0 10"/>
                        <DataGrid x:Name="AllReportsGrid"
                                  AutoGenerateColumns="False"
                                  Height="320"
                                  CanUserAddRows="False"
                                  RowBackground="White"
                                  AlternatingRowBackground="#F9FBFC"
                                  GridLinesVisibility="None"
                                  BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Operator" Binding="{Binding OperatorName}" Width="160"/>
                                <DataGridTextColumn Header="Field" Binding="{Binding Field}" Width="140"/>
                                <DataGridTextColumn Header="Date Submitted" Binding="{Binding DateSubmitted, StringFormat={}{0:g}}" Width="160"/>
                                <DataGridTextColumn Header="Gas Produced (MMSCFD)" Binding="{Binding GasQ}" Width="140"/>
                                <DataGridTextColumn Header="Oil Produced (BOPD)" Binding="{Binding LiqBOPD}" Width="140"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </Border>

        <!-- FOOTER -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 12 0 0">
            <TextBlock VerticalAlignment="Center"
                       Foreground="#666"
                       Margin="0 0 12 0">
                Prepared by PREYE
            </TextBlock>
        </StackPanel>
    </Grid>
</Window>
