<Window x:Class="ProductionCalc.Desktop.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NPS - Login"
        Height="450" Width="650"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <!-- Background Gradient -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#107C10" Offset="0.0"/>
                <!-- Green -->
                <GradientStop Color="#0078D7" Offset="0.5"/>
                <!-- Blue -->
                <GradientStop Color="#D83B01" Offset="1.0"/>
                <!-- Red -->
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Center Card -->
        <Border CornerRadius="20"
                Background="#1E1E2E"
                Padding="30"
                Width="650"
                HorizontalAlignment="Center"
                VerticalAlignment="Center" Height="450">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="0" Opacity="0.5"/>
            </Border.Effect>

            <StackPanel>
                <!-- Logo -->
                <Image Source="logo.png" 
                       Height="80" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,15"/>
                <TextBlock Text="Network Production Software (NPS)" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- Username -->
                <Grid Margin="0,0,0,15">
                    <!-- Wrap TextBox in a Border to achieve rounded corners -->
                    <Border CornerRadius="10"
                            Background="#2E2E3E"
                            BorderBrush="#0078D7"
                            BorderThickness="0">
                        <TextBox x:Name="txtUsername" 
                                 Height="40"
                                 Padding="10"
                                 Background="Transparent"
                                 Foreground="White"/>
                    </Border>
                    <TextBlock Text="Username"
                               Foreground="Gray"
                               Margin="15,0,0,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"
                               FontSize="14"
                               Visibility="{Binding Text.IsEmpty, ElementName=txtUsername, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </Grid>

                <!-- Password -->
                <PasswordBox x:Name="txtPassword" 
                             Height="40"
                             Padding="10"
                             Background="#2E2E3E"
                             Foreground="White"
                             BorderBrush="#D83B01"
                             BorderThickness="0"
                             Margin="0,0,0,25"/>

                <!-- Login Button -->
                <!-- FIX: Remove CornerRadius from Button, use a style for rounded corners -->
                <Button Content="Login"
                        Height="45"
                        Background="#107C10"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="Login_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="10"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                BorderBrush="{TemplateBinding BorderBrush}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Footer -->
                <TextBlock Text="Network Exploration And Production"
                           Foreground="Gray"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
