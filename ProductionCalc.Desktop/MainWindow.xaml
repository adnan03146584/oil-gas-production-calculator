<Window x:Class="ProductionCalc.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Network Production Software"
        Width="980" Height="720"
        WindowStartupLocation="CenterScreen"
        Background="#F6F8FA"
        FontFamily="Segoe UI">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header + Notification -->
        <StackPanel Grid.Row="0">
            <DockPanel Margin="0 0 0 12" LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="Production Software"
                               FontSize="22" FontWeight="Bold" Foreground="#1A73E8" />
                    <TextBlock Text="  •  Gas &amp; Liquid Metering"
                               Margin="8 0 0 0" VerticalAlignment="Center" Foreground="#666"/>
                </StackPanel>

                <!-- Session Info + Logout (animated) -->
                <StackPanel x:Name="SessionPanel"
                            Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            HorizontalAlignment="Right"
                            Opacity="0"
                            Margin="0,-20,0,0"
                            Loaded="SessionPanel_Loaded">
                    <TextBlock x:Name="txtUserDisplay"
                               VerticalAlignment="Center"
                               Foreground="#444"
                               FontWeight="SemiBold"
                               Margin="0 0 8 0"/>
                    <Button Content="Logout"
                            Click="Logout_Click"
                            Padding="10 4"
                            Background="#E74C3C"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"/>
                </StackPanel>
            </DockPanel>

            <!-- Notification Bar (collapses automatically) -->
            <Border x:Name="NotificationBar"
                    Background="#DFF0D8"
                    CornerRadius="6"
                    Padding="8"
                    Margin="0 0 0 8"
                    Visibility="Collapsed"
                    Opacity="0">
                <TextBlock x:Name="NotificationText" Foreground="#222"/>
            </Border>
        </StackPanel>

        <!-- Main content: two-column layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Tabs for Choke / Gas / Liquid inputs + My Reports -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="14" Margin="0 0 12 0">
                <TabControl>

                    <!-- Choke Setup Tab -->
                    <TabItem Header="Choke Setup">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="-8,0,7,0">
                            <StackPanel Margin="4">
                                <!-- (unchanged choke UI - same as before) -->
                                <TextBlock Text="Choke Selection" FontWeight="SemiBold" Margin="0 4"/>
                                <StackPanel Orientation="Horizontal" Margin="0 8" VerticalAlignment="Center">
                                    <TextBlock Text="Select Choke:" VerticalAlignment="Center" Margin="0 0 8 0"/>
                                    <ComboBox x:Name="ChokeSelector" Width="240" SelectionChanged="ChokeSelector_SelectionChanged">
                                        <ComboBoxItem Content="10/64" />
                                        <ComboBoxItem Content="12/64" />
                                        <ComboBoxItem Content="14/64" />
                                        <ComboBoxItem Content="16/64" />
                                        <ComboBoxItem Content="18/64" />
                                        <ComboBoxItem Content="20/64" />
                                        <ComboBoxItem Content="24/64" />
                                        <ComboBoxItem Content="28/64" />
                                        <ComboBoxItem Content="32/64" />
                                        <ComboBoxItem Content="36/64" />
                                        <ComboBoxItem Content="40/64" />
                                        <ComboBoxItem Content="44/64" />
                                        <ComboBoxItem Content="48/64" />
                                        <ComboBoxItem Content="52/64" />
                                        <ComboBoxItem Content="56/64" />
                                        <ComboBoxItem Content="60/64" />
                                        <ComboBoxItem Content="64/64" />
                                    </ComboBox>

                                    <Button Content="Save Choke (no overwrite)" Margin="12 0 0 0" Padding="8 4" Click="ApplyChokeToInputs_Click"/>
                                </StackPanel>

                                <UniformGrid Columns="2" Margin="0 8">
                                    <StackPanel Margin="6">
                                        <TextBlock>WHP (Wellhead Pressure, psia)</TextBlock>
                                        <TextBox x:Name="txtChokeWHP" />
                                    </StackPanel>
                                    <StackPanel Margin="6">
                                        <TextBlock>WHT (Flowing Temp, °F)</TextBlock>
                                        <TextBox x:Name="txtChokeWHT" />
                                    </StackPanel>
                                    <StackPanel Margin="6">
                                        <TextBlock>FLP (Flowline Pressure, psig)</TextBlock>
                                        <TextBox x:Name="txtChokeFLP" />
                                    </StackPanel>
                                    <StackPanel Margin="6">
                                        <TextBlock>Casing Pressure (psig)</TextBlock>
                                        <TextBox x:Name="txtChokeCasing" />
                                    </StackPanel>
                                    <StackPanel Margin="6">
                                        <TextBlock>Arrival Manifold Pressure (psig)</TextBlock>
                                        <TextBox x:Name="txtChokeArrival" />
                                    </StackPanel>
                                    <StackPanel Margin="6">
                                        <TextBlock>Wellhead BS&amp;W (%)</TextBlock>
                                        <TextBox x:Name="txtChokeBSW" />
                                    </StackPanel>
                                </UniformGrid>

                                <TextBlock Text="Note: These choke constants are report metadata and are saved independently (they do not automatically overwrite Gas/Liquid inputs)."
                                           FontStyle="Italic" Foreground="#666" Margin="6 8 0 0" TextWrapping="Wrap"/>

                                <Separator Margin="6 12"/>

                                <TextBlock Text="Inputs &amp; Constants (summary)" FontWeight="SemiBold" Margin="0 6" FontSize="16"/>

                                <ScrollViewer Height="400" VerticalScrollBarVisibility="Auto">
                                    <Grid Margin="0 6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid.RowDefinitions>
                                            <!-- same rows as before -->
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid.Resources>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontSize" Value="14"/>
                                                <Setter Property="Margin" Value="6"/>
                                            </Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="FontSize" Value="14"/>
                                                <Setter Property="Margin" Value="6"/>
                                                <Setter Property="MinWidth" Value="120"/>
                                            </Style>
                                        </Grid.Resources>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="ΔP (inH₂O)"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Text, ElementName=GasDP}"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Downstream Pressure (psig)"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Text, ElementName=GasDownstream}"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Flowing Temp (°F)"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Text, ElementName=GasTemp}"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Gas Specific Gravity"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Text, ElementName=GasSG}"/>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Meter Run Diameter (in)"/>
                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Text, ElementName=GasMeterD}"/>

                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Orifice Diameter (in)"/>
                                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Text, ElementName=GasOrificeD}"/>

                                        <TextBlock Grid.Row="6" Grid.Column="0" Text="CO₂ (%)"/>
                                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Text, ElementName=GasCO2}"/>

                                        <TextBlock Grid.Row="7" Grid.Column="0" Text="N₂ (%)"/>
                                        <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding Text, ElementName=GasN2}"/>

                                        <TextBlock Grid.Row="8" Grid.Column="0" Text="H₂S (ppm)"/>
                                        <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding Text, ElementName=GasH2S}"/>

                                        <TextBlock Grid.Row="9" Grid.Column="0" Text="Reservoir Pressure (psi)"/>
                                        <TextBox Grid.Row="9" Grid.Column="1" x:Name="txtReservoirPressure"/>

                                        <TextBlock Grid.Row="10" Grid.Column="0" Text="Oil API"/>
                                        <TextBox Grid.Row="10" Grid.Column="1" x:Name="txtOilAPI"/>

                                        <TextBlock Grid.Row="11" Grid.Column="0" Text="Start Meter (V1)"/>
                                        <TextBlock Grid.Row="11" Grid.Column="1" Text="{Binding Text, ElementName=LiqMeterStart}"/>

                                        <TextBlock Grid.Row="12" Grid.Column="0" Text="End Meter (V2)"/>
                                        <TextBlock Grid.Row="12" Grid.Column="1" Text="{Binding Text, ElementName=LiqMeterEnd}"/>

                                        <TextBlock Grid.Row="13" Grid.Column="0" Text="BS&amp;W (%)"/>
                                        <TextBlock Grid.Row="13" Grid.Column="1" Text="{Binding Text, ElementName=LiqBSW}"/>

                                        <TextBlock Grid.Row="14" Grid.Column="0" Text="Shrinkage Factor"/>
                                        <TextBlock Grid.Row="14" Grid.Column="1" Text="{Binding Text, ElementName=LiqShrinkage}"/>

                                        <TextBlock Grid.Row="15" Grid.Column="0" Text="Time Factor (hrs)"/>
                                        <TextBlock Grid.Row="15" Grid.Column="1" Text="{Binding Text, ElementName=LiqTimeFactor}"/>
                                    </Grid>
                                </ScrollViewer>

                                <Separator Margin="6 12"/>

                                <TextBlock Text="Operator Remarks" FontWeight="SemiBold" Margin="0 6"/>
                                <Border Background="#FBFDFF" CornerRadius="6" Padding="8" Margin="0 6 0 12">
                                    <RichTextBox x:Name="RemarksBox" Height="120" VerticalScrollBarVisibility="Auto"/>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Gas Tab -->
                    <TabItem Header="Gas Flow">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="4">
                                <TextBlock Text="Gas Inputs" FontWeight="SemiBold" Margin="0 4"/>
                                <UniformGrid Columns="2" Rows="5" Margin="0 8" HorizontalAlignment="Stretch">
                                    <!-- gas input controls (unchanged) -->
                                    <StackPanel Margin="6">
                                        <TextBlock>ΔP (inH₂O)</TextBlock>
                                        <TextBox x:Name="GasDP" />
                                    </StackPanel>
                                    <StackPanel Margin="6">
                                        <TextBlock>Downstream Pressure (psig)</TextBlock>
                                        <TextBox x:Name="GasDownstream" />
                                    </StackPanel>
                                    <StackPanel Margin="6">
                                        <TextBlock>Flowing Temp (°F)</TextBlock>
                                        <TextBox x:Name="GasTemp" />
                                    </StackPanel>
                                    <StackPanel Margin="6">
                                        <TextBlock>Gas Specific Gravity</TextBlock>
                                        <TextBox x:Name="GasSG" Text="0.784"/>
                                    </StackPanel>
                                    <StackPanel Margin="6">
                                        <TextBlock>Meter Run Diameter (in)</TextBlock>
                                        <TextBox x:Name="GasMeterD" Text="4.000"/>
                                    </StackPanel>
                                    <StackPanel Margin="6">
                                        <TextBlock>Orifice Diameter (in)</TextBlock>
                                        <TextBox x:Name="GasOrificeD" Text="1.750"/>
                                    </StackPanel>
                                    <StackPanel Margin="6">
                                        <TextBlock>CO₂ (%)</TextBlock>
                                        <TextBox x:Name="GasCO2" Text="0"/>
                                    </StackPanel>
                                    <StackPanel Margin="6">
                                        <TextBlock>N₂ (%)</TextBlock>
                                        <TextBox x:Name="GasN2" Text="0"/>
                                    </StackPanel>
                                    <StackPanel Margin="6">
                                        <TextBlock>H₂S (ppm)</TextBlock>
                                        <TextBox x:Name="GasH2S" Text="0"/>
                                    </StackPanel>
                                </UniformGrid>

                                <StackPanel Orientation="Horizontal" Margin="6">
                                    <Button Content="Calculate Gas" Width="150" Height="38"
                                            Background="#1A73E8" Foreground="White"
                                            Click="CalculateGas_Click"/>
                                    <Button Content="Clear Gas" Width="100" Margin="8 0 0 0"
                                            Click="ClearGas_Click"/>
                                </StackPanel>

                                <Border Background="#FBFDFF" CornerRadius="6" Padding="10" Margin="0 12 0 0">
                                    <TextBlock x:Name="GasResult" FontFamily="Consolas" TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Liquid Tab -->
                    <TabItem Header="Liquid Flow">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="4">
                                <TextBlock Text="Liquid Inputs" FontWeight="SemiBold" Margin="0 4"/>
                                <UniformGrid Columns="2" Margin="0 8">
                                    <StackPanel Margin="6">
                                        <TextBlock>Start Meter (V1)</TextBlock>
                                        <TextBox x:Name="LiqMeterStart" />
                                    </StackPanel>
                                    <StackPanel Margin="6">
                                        <TextBlock>End Meter (V2)</TextBlock>
                                        <TextBox x:Name="LiqMeterEnd" />
                                    </StackPanel>
                                    <StackPanel Margin="6">
                                        <TextBlock>BS&amp;W (%)</TextBlock>
                                        <TextBox x:Name="LiqBSW" Text="0" />
                                    </StackPanel>
                                    <StackPanel Margin="6">
                                        <TextBlock>Shrinkage Factor / Corrected Meter Factor</TextBlock>
                                        <TextBox x:Name="LiqShrinkage" Text="1.0"/>
                                    </StackPanel>
                                    <StackPanel Margin="6">
                                        <TextBlock>Time Factor (hrs, default 24)</TextBlock>
                                        <TextBox x:Name="LiqTimeFactor" Text="24"/>
                                    </StackPanel>
                                </UniformGrid>

                                <StackPanel Orientation="Horizontal" Margin="6">
                                    <Button Content="Calculate Liquid" Width="150" Height="38"
                                            Background="#1A73E8" Foreground="White"
                                            Click="CalculateLiquid_Click"/>
                                    <Button Content="Clear Liquid" Width="100" Margin="8 0 0 0"
                                            Click="ClearLiquid_Click"/>
                                </StackPanel>

                                <Border Background="#FBFDFF" CornerRadius="6" Padding="10" Margin="0 12 0 0">
                                    <TextBlock x:Name="LiquidOutput" FontFamily="Consolas" TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- NEW: My Reports Tab (operator review) -->
                    <TabItem Header="My Reports">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="0" Margin="0 0 0 8">
                                <Button x:Name="btnRefreshReports" Content="Refresh Reports" Click="BtnRefreshReports_Click" Width="140" Height="32" Margin="0 0 8 0"/>
                                <Button x:Name="btnOpenReport" Content="Open Report" Click="BtnOpenReport_Click" Width="120" Height="32"/>
                            </StackPanel>

                            <DataGrid x:Name="dgMyReports" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" MinHeight="260">
                                <DataGrid.Resources>
                                    <!-- Row color based on Status -->
                                    <Style TargetType="DataGridRow">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Approved">
                                                <Setter Property="Background" Value="#DFF0D8"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                <Setter Property="Background" Value="#FFF8DC"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Rejected">
                                                <Setter Property="Background" Value="#F8D7DA"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.Resources>

                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                                    <DataGridTextColumn Header="Title" Binding="{Binding ReportTitle}" Width="*"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110"/>
                                    <DataGridTextColumn Header="Supervisor Comment" Binding="{Binding SupervisorComment}" Width="220"/>
                                    <DataGridTextColumn Header="Submitted" Binding="{Binding DateSubmitted}" Width="160"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock Grid.Row="2" Text="Select a report and click 'Open Report' to view the file. Status will update when supervisor reviews." 
                                       FontStyle="Italic" Foreground="#666" Margin="4"/>
                        </Grid>
                    </TabItem>

                </TabControl>
            </Border>

            <!-- Right: Quick info / actions -->
            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="14">
                <StackPanel>
                    <TextBlock Text="Actions" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Margin="0 12">
                        <Button x:Name="SaveHourlyBtn" Content="Save Hourly" Width="120" Height="36" Background="#F39C12" Foreground="White" Click="SaveHourly_Click"/>
                        <Button x:Name="ClearSavedBtn" Content="Clear Saved" Width="100" Height="36" Margin="8 0 0 0" Click="ClearSaved_Click"/>
                    </StackPanel>

                    <Button x:Name="ExportBtn" Content="Export Daily Report (Excel)" 
                            Background="#34A853" Foreground="White" Margin="0 12" Height="40" 
                            Click="ExportExcel_Click"/>
                    <Button x:Name="SubmitBtn" Content="Submit Report to Supervisor" Background="#1A73E8" Foreground="White"
                            Margin="0 6 0 0" Height="40" Click="SubmitToSupervisor_Click"/>

                    <Separator Margin="0 10"/>
                    <TextBlock Text="Last Results Preview" FontWeight="SemiBold" Margin="0 8"/>
                    <ScrollViewer Height="120">
                        <StackPanel>
                            <TextBlock Text="Gas (short):" FontWeight="Bold" Margin="0 6 0 2"/>
                            <TextBlock x:Name="GasPreview" FontFamily="Consolas" TextWrapping="Wrap" />
                            <TextBlock Text="---" Margin="0 6"/>
                            <TextBlock Text="Liquid (short):" FontWeight="Bold" Margin="0 6 0 2"/>
                            <TextBlock x:Name="LiquidPreview" FontFamily="Consolas" TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>

                    <Separator Margin="0 10"/>
                    <TextBlock Text="Saved Hourly Records" FontWeight="SemiBold" Margin="0 8"/>
                    <DataGrid x:Name="SavedEntriesGrid" AutoGenerateColumns="False" Height="260" IsReadOnly="True" MinWidth="700"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="140"/>
                            <DataGridTextColumn Header="Choke" Binding="{Binding ChokeSize}" Width="80"/>
                            <DataGridTextColumn Header="Gas Q (MMSCFD)" Binding="{Binding GasQ}" Width="110"/>
                            <DataGridTextColumn Header="BOPD" Binding="{Binding LiqBOPD}" Width="100"/>
                            <DataGridTextColumn Header="Meter Δ" Binding="{Binding LiqMeterDifference}" Width="80"/>
                            <!-- extra columns (placeholder) - horizontal scrollbar will appear as needed -->
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 12 0 0">
            <TextBlock VerticalAlignment="Center" Foreground="#666" Margin="0 0 12 0">Prepared by PREYE</TextBlock>
        </StackPanel>
    </Grid>
</Window>
