<Window x:Class="ProductionCalc.Desktop.SupervisorDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Supervisor Dashboard"
        Width="1100" Height="740"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        FontFamily="Segoe UI"
        FontSize="13">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="#1A73E8" CornerRadius="10" Padding="12 10" Margin="0 0 0 12">
            <DockPanel>
                <TextBlock Text="Supervisor Dashboard"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="White"
                           DockPanel.Dock="Left"/>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="txtSupervisorDisplay"
                               Foreground="White"
                               FontWeight="SemiBold"
                               Margin="0 0 12 0"
                               VerticalAlignment="Center"/>
                    <Button Content="Logout"
                            Click="Logout_Click"
                            Padding="10 5"
                            Background="White"
                            Foreground="#1A73E8"
                            BorderBrush="#1A73E8"
                            BorderThickness="1"
                            FontWeight="SemiBold"
                            Cursor="Hand"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3.5*"/>
                <ColumnDefinition Width="2.5*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Report List -->
            <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="14">
                <StackPanel>
                    <TextBlock Text="Submitted Reports"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Margin="0 0 0 8"
                               Foreground="#333"/>

                    <!-- Search TextBox -->
                    <DockPanel Margin="0 0 0 10">
                        <TextBox x:Name="txtSearch"
                                 Margin="0"
                                 Padding="8"
                                 BorderBrush="#D0D7DE"
                                 BorderThickness="1"
                                 Background="#FBFBFB"
                                 TextChanged="Search_TextChanged"/>
                        <TextBlock Text="🔍 Search by Operator or Date..."
                                   Foreground="#999"
                                   Margin="10,6,0,0"
                                   IsHitTestVisible="False"
                                   Visibility="{Binding Text.IsEmpty, ElementName=txtSearch, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </DockPanel>

                    <DataGrid x:Name="ReportGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionChanged="ReportGrid_SelectionChanged"
                              RowBackground="White"
                              AlternatingRowBackground="#F9FBFC"
                              BorderThickness="0"
                              GridLinesVisibility="None"
                              Height="520">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Operator" Binding="{Binding OperatorName}" Width="130"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding DateSubmitted}" Width="120"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- Right: Report Details -->
            <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="14">
                <StackPanel>
                    <TextBlock Text="Report Details"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#333"
                               Margin="0 0 0 8"/>

                    <ScrollViewer Height="250">
                        <TextBlock x:Name="txtReportDetails"
                                   TextWrapping="Wrap"
                                   FontFamily="Consolas"
                                   Foreground="#444"
                                   LineHeight="20"
                                   Text="Select a report from the list to view details."/>
                    </ScrollViewer>

                    <Separator Margin="0 10"/>

                    <TextBlock Text="Supervisor Comment"
                               FontWeight="SemiBold"
                               Margin="0 0 0 4"/>
                    <TextBox x:Name="txtSupervisorComments"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="100"
                             Padding="8"
                             VerticalScrollBarVisibility="Auto"
                             BorderBrush="#D0D7DE"
                             BorderThickness="1"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 12 0 0">
                        <Button Content="Approve"
                                Width="110"
                                Background="#34A853"
                                Foreground="White"
                                BorderThickness="0"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                Click="Approve_Click"
                                Margin="0 0 8 0"/>

                        <Button Content="Reject"
                                Width="110"
                                Background="#E74C3C"
                                Foreground="White"
                                BorderThickness="0"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                Click="Reject_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
